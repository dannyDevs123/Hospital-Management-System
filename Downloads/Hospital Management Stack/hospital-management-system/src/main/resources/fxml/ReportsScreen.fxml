<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hospital.controller.ReportsController"
      spacing="20" styleClass="content-area">
    
    <!-- Header -->
    <HBox styleClass="toolbar" alignment="CENTER_LEFT" spacing="15">
        <Label text="Reports &amp; Analytics" styleClass="toolbar-title"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>
    
    <!-- Report Configuration -->
    <HBox spacing="20">
        <VBox styleClass="form-panel" HBox.hgrow="ALWAYS" spacing="15">
            <Label text="Report Configuration" styleClass="section-header"/>
            
            <GridPane vgap="12" hgap="15">
                <columnConstraints>
                    <ColumnConstraints prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                
                <!-- Report Type -->
                <Label text="Report Type:*" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="reportTypeCombo" promptText="Select report type"
                          GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>
                
                <!-- Date Range -->
                <Label text="Start Date:*" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <DatePicker fx:id="startDatePicker" promptText="Select start date"
                            GridPane.rowIndex="0" GridPane.columnIndex="3" maxWidth="Infinity"/>
                
                <!-- End Date -->
                <Label text="End Date:*" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <DatePicker fx:id="endDatePicker" promptText="Select end date"
                            GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>
            </GridPane>
            
            <!-- Error Label -->
            <Label fx:id="formErrorLabel" styleClass="error-message" visible="false" managed="false"/>
            
            <!-- Buttons -->
            <HBox spacing="10">
                <Button text="Generate Report" styleClass="button, button-primary" 
                        onAction="#handleGenerateReport" prefWidth="130"/>
                <Button text="Export PDF" styleClass="button, button-success" 
                        onAction="#handleExportPDF" prefWidth="100"/>
                <Button text="Preview" styleClass="button, button-secondary" 
                        onAction="#handlePreview" prefWidth="80"/>
                <Button text="Clear" styleClass="button, button-secondary" 
                        onAction="#handleClear" prefWidth="70"/>
            </HBox>
        </VBox>
    </HBox>
    
    <!-- Report Preview -->
    <VBox styleClass="form-panel" VBox.vgrow="ALWAYS" spacing="15">
        <Label text="Report Preview" styleClass="section-header"/>
        <TextArea fx:id="previewArea" editable="false" VBox.vgrow="ALWAYS"
                  promptText="Report preview will appear here after generation..."
                  style="-fx-font-family: 'Consolas', 'Courier New', monospace; -fx-font-size: 12px;"/>
    </VBox>
</VBox>
