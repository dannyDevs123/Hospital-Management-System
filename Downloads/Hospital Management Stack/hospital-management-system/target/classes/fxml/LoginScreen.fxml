<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.DropShadow?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hospital.controller.LoginScreenController"
           stylesheets="@../css/style.css"
           styleClass="login-container"
           prefWidth="500" prefHeight="600">
    
    <VBox alignment="CENTER">
        <VBox styleClass="login-card" alignment="CENTER" spacing="25" maxWidth="400">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            
            <!-- Logo -->
            <StackPane>
                <Circle radius="35" fill="#dbeafe"/>
                <Circle radius="28" fill="#2563EB"/>
                <Label text="+" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;"/>
            </StackPane>
            
            <!-- Title -->
            <VBox alignment="CENTER" spacing="5">
                <Label text="Welcome Back" styleClass="login-title"/>
                <Label text="Sign in to your account" styleClass="login-subtitle"/>
            </VBox>
            
            <!-- Form -->
            <VBox spacing="18" prefWidth="320">
                <!-- Username -->
                <VBox spacing="6">
                    <Label text="Username" styleClass="form-label"/>
                    <TextField fx:id="usernameField" promptText="Enter your username" 
                               styleClass="text-field"/>
                </VBox>
                
                <!-- Password -->
                <VBox spacing="6">
                    <Label text="Password" styleClass="form-label"/>
                    <StackPane>
                        <PasswordField fx:id="passwordField" promptText="Enter your password"/>
                        <TextField fx:id="visiblePasswordField" promptText="Enter your password" 
                                   visible="false" managed="false"/>
                        <Button fx:id="togglePasswordBtn" text="👁" 
                                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8;"
                                StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin>
                                <Insets right="10"/>
                            </StackPane.margin>
                        </Button>
                    </StackPane>
                </VBox>
                
                <!-- Error Message -->
                <Label fx:id="errorLabel" text="" styleClass="error-message" visible="false" managed="false"/>
                
                <!-- Login Button -->
                <Button fx:id="loginButton" text="Sign In" 
                        styleClass="button, button-primary"
                        prefWidth="320" prefHeight="45"
                        onAction="#handleLogin"/>
                
                <!-- Forgot Password -->
                <HBox alignment="CENTER">
                    <Hyperlink fx:id="forgotPasswordLink" text="Forgot Password?" 
                               onAction="#handleForgotPassword"/>
                </HBox>
            </VBox>
            
            <!-- Divider -->
            <HBox alignment="CENTER" spacing="10">
                <Region prefWidth="100" style="-fx-border-color: transparent transparent #e2e8f0 transparent; -fx-border-width: 0 0 1 0;"/>
                <Label text="or" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                <Region prefWidth="100" style="-fx-border-color: transparent transparent #e2e8f0 transparent; -fx-border-width: 0 0 1 0;"/>
            </HBox>
            
            <!-- Default Credentials Info -->
            <VBox alignment="CENTER" spacing="4" 
                  style="-fx-background-color: #f8fafc; -fx-background-radius: 8px; -fx-padding: 12px;">
                <Label text="Default Credentials" 
                       style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-font-weight: bold;"/>
                <Label text="Username: admin  |  Password: admin123" 
                       style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
            </VBox>
        </VBox>
    </VBox>
</StackPane>
